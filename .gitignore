# Ruta: /.gitignore

# --- WordPress & Plugin Specific ---
# Ignorar los paquetes comprimidos del plugin
*.zip

# Ignorar logs de error
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Visual Studio Code ---
.vscode/
*.code-workspace
.history/

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Development Tools ---
node_modules/
vendor/
.env
.phpunit.result.cache

# --- CREA Specific ---
# Ignorar los archivos generados dinámicamente (recursos estáticos y subidas de usuarios)
api/*.csv
api/*.json
uploads/

# --- Utilidades Locales ---
# Ignorar scripts y reportes de estructura local
estructura.bat
estructura.txt